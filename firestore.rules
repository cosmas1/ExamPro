rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function emailVerified() {
      return request.auth.token.email_verified == true;
    }
    
    function getUserData() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : {};
    }
    
    function isStaff() {
      let userData = getUserData();
      let role = userData.get('role', 'student');
      return isSignedIn() && (
        request.auth.token.email == 'musaukulenga1@gmail.com' || 
        role == 'admin' || 
        role == 'teacher' ||
        role == 'staff'
      );
    }

    function isAdmin() {
      let userData = getUserData();
      let role = userData.get('role', 'student');
      return isSignedIn() && (
        request.auth.token.email == 'musaukulenga1@gmail.com' || 
        role == 'admin'
      );
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    // -------------------------------------------------------------------------
    // VALIDATION HELPERS
    // -------------------------------------------------------------------------
    
    function isValidUser(data) {
      return data.email is string && 
             data.role in ['admin', 'teacher', 'student', 'staff'] &&
             data.keys().hasAll(['email', 'role']);
    }
    
    function isValidExam(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.sessionId is string &&
             data.keys().hasAll(['title', 'sessionId']);
    }
    
    // -------------------------------------------------------------------------
    // RULES
    // -------------------------------------------------------------------------
    
    match /{document=**} {
      allow read, write: if false;
    }
    
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow list: if isStaff();
      allow create: if isSignedIn(); // Allow initial registration
      allow update: if (isSignedIn() && request.auth.uid == userId) || isStaff();
      allow delete: if isAdmin();
    }

    match /admission_to_email/{admissionId} {
      allow get: if true;
    }
    
    match /sessions/{sessionId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
    
    match /categories/{catId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
    
    match /subcategories/{subId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
    
    match /exams/{examId} {
      allow read: if isSignedIn() && (
        isStaff() || 
        (existing().status == 'published' && existing().sessionId == getUserData().sessionId)
      );
      allow write: if isStaff();

      match /questions/{qId} {
        allow read: if isSignedIn() && (
          isStaff() || 
          get(/databases/$(database)/documents/exams/$(examId)).data.status == 'published'
        );
        allow write: if isStaff();
      }
    }
    
    match /questions/{qId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
    
    match /submissions/{subId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (existing().userId == request.auth.uid || isStaff());
      allow delete: if isAdmin();
    }
  }
}
